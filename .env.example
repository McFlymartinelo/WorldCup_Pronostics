# ── Serveur ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Sécurité (obligatoire en production) ─────────────────────────
JWT_SECRET=changez-moi-avec-openssl-rand-hex-32
ADMIN_PSEUDO=admin
ADMIN_PASSWORD=changez-moi

# ── Base de données ──────────────────────────────────────────────
# SQLite local (dev / tests) :
DB_PATH=data/database.sqlite
# Turso (prod recommandé) — si TURSO_DATABASE_URL est défini, il remplace SQLite :
# TURSO_DATABASE_URL=libsql://votre-db.turso.io
# TURSO_AUTH_TOKEN=

# ── API Football (football-data.org) ─────────────────────────────
FOOTBALL_API_KEY=
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4
COMPETITION_CODE=WC

# ── API BSD (sélections / forme) ───────────────────────────────
BSD_API_KEY=

# ── Confrontations directes (CSV international_results) ─────────
# H2H_CSV_URL=https://raw.githubusercontent.com/martj42/international_results/master/results.csv

# ── Notifications push (optionnel) ───────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:votre@email.com

# ── Scheduler (cron) ─────────────────────────────────────────────
CRON_SCORES_INTERVAL=*/5 * * * *
CRON_FIXTURES_INTERVAL=0 */6 * * *

# ── Rappels pronos oubliés (optionnel, défaut 120 min avant) ───
PREDICTION_REMINDER_MINUTES=120
